# Copy this to .env and fill in your own values.
# .env is in .gitignore — never committed.
#
# Get free Groq keys at https://console.groq.com/keys

# --- Single-key mode (simplest) ------------------------------------------
# Use this if you only have one Groq account.
GROQ_API_KEY=gsk_REPLACE_ME

# --- Rotation mode (multiple keys) ---------------------------------------
# If you set GROQ_API_KEY_1 through GROQ_API_KEY_6 (or _9), the client will
# auto-rotate when one key hits its daily tokens-per-day cap. This combines
# multiple free-tier accounts into a higher effective daily quota.
#
# Important: rotating separate free-tier Groq accounts is against Groq's TOS.
# Detection => account suspension. The legitimate equivalent is upgrading one
# account's Dev Tier — actual cost for our full experiment is well under $1.
#
# GROQ_API_KEY_1=gsk_...
# GROQ_API_KEY_2=gsk_...
# GROQ_API_KEY_3=gsk_...
# GROQ_API_KEY_4=gsk_...
# GROQ_API_KEY_5=gsk_...
# GROQ_API_KEY_6=gsk_...

# --- Optional fallbacks (other free tiers; only fill if needed) ----------
HUGGINGFACE_TOKEN=
TOGETHER_API_KEY=
